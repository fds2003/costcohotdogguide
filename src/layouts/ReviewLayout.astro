---
import BaseLayout from './BaseLayout.astro';
import RelatedProducts from '../components/RelatedProducts.astro';

export interface Props {
  title: string;
  description: string;
  productName: string;
  brand?: string;
  rating?: number;
  priceRange?: string;
  pros?: string[];
  cons?: string[];
  verdict?: string;
  amazonUrl?: string;
  relatedGuides?: Array<{ title: string; href: string; description: string }>;
  publishedAt?: string;
  modifiedAt?: string;
  image?: string;
}

const {
  title,
  description,
  productName,
  brand,
  rating = 0,
  priceRange,
  pros = [],
  cons = [],
  verdict,
  amazonUrl,
  relatedGuides = [],
  publishedAt = new Date().toISOString().split('T')[0],
  modifiedAt = new Date().toISOString().split('T')[0],
  image,
} = Astro.props;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": productName,
  "brand": brand ? { "@type": "Brand", "name": brand } : undefined,
  "image": image,
  "description": description,
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": rating,
      "bestRating": 5
    },
    "author": {
      "@type": "Organization",
      "name": "Costco Hot Dog Guide"
    }
  },
  "offers": priceRange ? {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "url": amazonUrl
  } : undefined
};
---

<BaseLayout
  title={title}
  description={description}
  type="review"
  publishedAt={publishedAt}
  modifiedAt={modifiedAt}
  image={image}
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Orange breadcrumb indicator -->
    <nav class="mb-6">
      <ol class="flex items-center space-x-2 text-sm">
        <li><a href="/" class="text-gray-500 hover:text-red-700">Home</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/reviews/" class="text-gray-500 hover:text-red-700">Reviews</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-orange-600 font-medium">{productName}</li>
      </ol>
      <div class="mt-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800">
        <span class="w-2 h-2 bg-orange-500 rounded-full mr-1.5"></span>
        Product Review Layer
      </div>
    </nav>

    <!-- FTC Disclosure -->
    <div class="bg-gray-100 border-l-4 border-gray-400 rounded-r-lg p-4 mb-6 text-sm text-gray-600">
      <strong>Disclosure:</strong> As an Amazon Associate, we earn from qualifying purchases. This review is based on research and publicly available information. Prices and availability are subject to change.
    </div>

    <article class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="p-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">{title}</h1>
        {brand && <p class="text-lg text-gray-500 mb-4">by {brand}</p>}

        <!-- Rating badge -->
        {rating > 0 && (
          <div class="flex items-center mb-6">
            <div class="flex items-center bg-orange-50 px-3 py-1.5 rounded-lg border border-orange-200">
              <span class="text-2xl font-bold text-orange-700 mr-2">{rating}</span>
              <div class="flex text-orange-400">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class={`w-5 h-5 ${i < Math.floor(rating) ? 'text-orange-400' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            {priceRange && (
              <span class="ml-4 text-lg font-semibold text-green-700">{priceRange}</span>
            )}
          </div>
        )}

        <!-- Amazon CTA -->
        {amazonUrl && (
          <a
            href={amazonUrl}
            target="_blank"
            rel="noopener sponsored"
            class="inline-flex items-center px-6 py-3 bg-orange-600 text-white font-semibold rounded-lg hover:bg-orange-700 transition mb-8"
            onclick="if(typeof gtag!=='undefined')gtag('event','affiliate_click',{link_id:'review_main_cta',category:'review'});"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3z" />
            </svg>
            See Price on Amazon
          </a>
        )}

        <!-- Main content -->
        <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
          <slot />
        </div>

        <!-- Pros & Cons -->
        {(pros.length > 0 || cons.length > 0) && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8 pt-6 border-t border-gray-100">
            {pros.length > 0 && (
              <div class="bg-green-50 rounded-lg p-5 border border-green-200">
                <h3 class="text-lg font-semibold text-green-800 mb-3 flex items-center">
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Pros
                </h3>
                <ul class="space-y-2">
                  {pros.map(pro => (
                    <li class="flex items-start text-gray-700">
                      <span class="text-green-500 mr-2 mt-1">&#10003;</span>
                      {pro}
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {cons.length > 0 && (
              <div class="bg-red-50 rounded-lg p-5 border border-red-200">
                <h3 class="text-lg font-semibold text-red-800 mb-3 flex items-center">
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                  Cons
                </h3>
                <ul class="space-y-2">
                  {cons.map(con => (
                    <li class="flex items-start text-gray-700">
                      <span class="text-red-500 mr-2 mt-1">&#10007;</span>
                      {con}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )}

        <!-- Verdict -->
        {verdict && (
          <div class="mt-8 bg-orange-50 border-l-4 border-orange-500 rounded-r-lg p-6">
            <h3 class="text-lg font-semibold text-orange-900 mb-2">Our Verdict</h3>
            <p class="text-gray-700">{verdict}</p>
          </div>
        )}

        <!-- Secondary Amazon CTA -->
        {amazonUrl && (
          <div class="mt-8 text-center">
            <a
              href={amazonUrl}
              target="_blank"
              rel="noopener sponsored"
              class="inline-flex items-center px-8 py-4 bg-orange-600 text-white font-bold text-lg rounded-lg hover:bg-orange-700 transition"
              onclick="if(typeof gtag!=='undefined')gtag('event','affiliate_click',{link_id:'review_bottom_cta',category:'review'});"
            >
              Check Current Price on Amazon
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        )}
      </div>
    </article>

    <!-- Related Guides -->
    {relatedGuides.length > 0 && (
      <section class="mt-8 bg-orange-50 border border-orange-200 rounded-xl p-6">
        <h3 class="text-lg font-bold text-orange-900 mb-4 flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          Related Guides
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {relatedGuides.map(guide => (
            <a
              href={guide.href}
              class="block bg-white rounded-lg p-4 border border-orange-200 hover:border-orange-400 hover:shadow-md transition group"
              onclick="if(typeof gtag!=='undefined')gtag('event','funnel_progression',{from_stage:'C',to_stage:guide.href.includes('/tutorials/')?'B':'A',target_url:guide.href,source_url:window.location.pathname});"
            >
              <h4 class="font-semibold text-orange-800 group-hover:text-orange-600">{guide.title}</h4>
              <p class="text-sm text-gray-600 mt-1">{guide.description}</p>
              <span class="text-xs text-orange-600 font-medium mt-2 inline-block group-hover:underline">Read guide &rarr;</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Stage C: High-ticket products -->
    <RelatedProducts funnelStage="C" title="Top Picks" maxItems={3} />
  </div>
</BaseLayout>
