---
import adsConfig from '../data/ads.json';

export interface Props {
  slot?: string;
  type?: 'display' | 'in-article' | 'native' | 'sticky' | 'banner';
  format?: 'auto' | 'rectangle' | 'leaderboard' | 'skyscraper' | 'medium-rectangle' | 'mobile-banner';
  className?: string;
  minHeight?: string;
}

const {
  slot = 'default',
  type = 'display',
  format = 'auto',
  className = '',
  minHeight = '250px'
} = Astro.props;

const isEnabled = adsConfig.enabled;
const showPlaceholder = !isEnabled && adsConfig.placeholder.showInDev;

const adStyles: Record<string, string> = {
  'auto': 'display:block;',
  'rectangle': 'display:inline-block;width:300px;height:250px;',
  'leaderboard': 'display:inline-block;width:728px;height:90px;max-width:100%;',
  'skyscraper': 'display:inline-block;width:160px;height:600px;',
  'medium-rectangle': 'display:inline-block;width:300px;height:250px;max-width:100%;',
  'mobile-banner': 'display:inline-block;width:320px;height:50px;max-width:100%;'
};

const responsiveStyle = format === 'auto'
  ? 'display:block;width:100%;'
  : adStyles[format] || adStyles.auto;

const placeholderLabel = adsConfig.placeholder.label;

const isMobileBanner = format === 'mobile-banner';
const mobileOnlyClass = isMobileBanner ? 'block md:hidden' : '';
---

{isEnabled && adsConfig.network === 'adsense' && (
  <ins
    class={`adsbygoogle ${mobileOnlyClass} ${className}`}
    style={responsiveStyle}
    data-ad-client={adsConfig.adsense.clientId}
    data-ad-slot={adsConfig.adsense.slots[slot as keyof typeof adsConfig.adsense.slots] || slot}
    data-ad-format={format === 'auto' ? 'auto' : undefined}
    data-full-width-responsive={format === 'auto' ? 'true' : undefined}
  />
  <script is:inline>
    (window.adsbygoogle = window.adsbygoogle || []).push({});
  </script>
)}

{isEnabled && adsConfig.network === 'medianet' && (
  <div id={`mN-${slot}`} class={`${mobileOnlyClass} ${className}`} style={responsiveStyle}>
    <script is:inline define:vars={{ cid: adsConfig.medianet.cid, crid: adsConfig.medianet.crid, slotId: slot }}>
      try {
        window._mNHandle = window._mNHandle || {};
        window._mNHandle.queue = window._mNHandle.queue || [];
        window._mNHandle.queue.push(function() {
          window._mNDetails.loadTag(crid, "300x250", "mN-" + slotId);
        });
      } catch(e) {}
    </script>
  </div>
)}

{isEnabled && adsConfig.network === 'adsterra' && type === 'banner' && (
  <div class={`max-w-full overflow-hidden flex justify-center ${mobileOnlyClass} ${className}`}>
    <script is:inline define:vars={{
      key: (adsConfig.adsterra as any)?.banners?.[slot]?.key || slot,
      width: (adsConfig.adsterra as any)?.banners?.[slot]?.width || 728,
      height: (adsConfig.adsterra as any)?.banners?.[slot]?.height || 90
    }}>
      atOptions = {
        'key' : key,
        'format' : 'iframe',
        'height' : height,
        'width' : width,
        'params' : {}
      };
    </script>
    <script is:inline src={`https://www.highperformanceformat.com/${(adsConfig.adsterra as any)?.banners?.[slot]?.key || slot}/invoke.js`}></script>
  </div>
)}

{isEnabled && adsConfig.network === 'adsterra' && type !== 'banner' && (
  <div id={`container-${(adsConfig.adsterra as any)?.slots?.[slot] || slot}`} class={className}></div>
)}

{showPlaceholder && (
  <div
    class={`bg-gray-100 border-2 border-dashed border-gray-300 rounded-lg flex flex-col items-center justify-center text-gray-400 ${mobileOnlyClass} ${className}`}
    style={`min-height: ${minHeight}; ${responsiveStyle}`}
  >
    <svg class="w-8 h-8 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
    </svg>
    <span class="text-sm font-medium">{placeholderLabel}</span>
    <span class="text-xs mt-1 opacity-70">{type} / {format}</span>
    <span class="text-xs opacity-50 mt-1">Slot: {slot}</span>
  </div>
)}
