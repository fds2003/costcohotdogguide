---
import nutritionData from '../data/nutrition.json';

const ww = nutritionData.wwPoints;
const calcData = {
  baseHotDog: ww.baseHotDog,
  baseHotDogNoBun: ww.baseHotDogNoBun,
  bun: ww.bun,
  ketchup: ww.ketchup,
  mustard: ww.mustard,
  relish: ww.relish,
  onions: ww.onions
};
---

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8" id="ww-calculator">
  <h3 class="text-xl font-bold text-gray-900 mb-2">Weight Watchers Points Calculator</h3>
  <p class="text-gray-600 mb-6">Calculate SmartPoints for your Costco hot dog based on your customizations. The base hot dog with bun is <strong>{calcData.baseHotDog} points</strong>.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-3">
      <h4 class="font-semibold text-gray-800">Customizations</h4>
      <label class="flex items-center space-x-3 cursor-pointer p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition">
        <input type="checkbox" id="ww-bun" checked class="w-5 h-5 text-red-600 rounded focus:ring-red-500" />
        <div>
          <span class="text-gray-700">Include Bun</span>
          <span class="text-xs text-gray-500 block">+{calcData.bun} points</span>
        </div>
      </label>
      <label class="flex items-center space-x-3 cursor-pointer p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition">
        <input type="checkbox" id="ww-ketchup" class="w-5 h-5 text-red-600 rounded focus:ring-red-500" />
        <div>
          <span class="text-gray-700">Add Ketchup</span>
          <span class="text-xs text-gray-500 block">+{calcData.ketchup} points</span>
        </div>
      </label>
      <label class="flex items-center space-x-3 cursor-pointer p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition">
        <input type="checkbox" id="ww-mustard" checked class="w-5 h-5 text-red-600 rounded focus:ring-red-500" />
        <div>
          <span class="text-gray-700">Add Mustard</span>
          <span class="text-xs text-gray-500 block">+{calcData.mustard} points</span>
        </div>
      </label>
      <label class="flex items-center space-x-3 cursor-pointer p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition">
        <input type="checkbox" id="ww-relish" class="w-5 h-5 text-red-600 rounded focus:ring-red-500" />
        <div>
          <span class="text-gray-700">Add Relish</span>
          <span class="text-xs text-gray-500 block">+{calcData.relish} points</span>
        </div>
      </label>
      <label class="flex items-center space-x-3 cursor-pointer p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition">
        <input type="checkbox" id="ww-onions" class="w-5 h-5 text-red-600 rounded focus:ring-red-500" />
        <div>
          <span class="text-gray-700">Add Onions</span>
          <span class="text-xs text-gray-500 block">+{calcData.onions} points</span>
        </div>
      </label>
    </div>

    <div class="bg-blue-50 rounded-xl p-6 flex flex-col justify-center">
      <div class="text-center mb-6">
        <p class="text-sm text-blue-700 font-medium uppercase tracking-wide">Total SmartPoints</p>
        <p class="text-6xl font-bold text-blue-800 mt-2" id="ww-total">14</p>
        <p class="text-sm text-blue-600 mt-1" id="ww-delta">Base value</p>
      </div>

      <div class="space-y-3">
        <div class="flex justify-between items-center p-3 bg-white rounded-lg">
          <span class="text-gray-600">Base hot dog</span>
          <span class="font-medium text-gray-900" id="ww-base-display">14 pts</span>
        </div>
        <div class="flex justify-between items-center p-3 bg-white rounded-lg">
          <span class="text-gray-600">Add-ons</span>
          <span class="font-medium text-gray-900" id="ww-addons">0 pts</span>
        </div>
        <div class="flex justify-between items-center p-3 bg-blue-100 rounded-lg">
          <span class="font-medium text-blue-900">Total</span>
          <span class="font-bold text-blue-900" id="ww-grand">14 pts</span>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6 bg-yellow-50 rounded-lg p-4 border border-yellow-200">
    <p class="text-sm text-yellow-800">
      <strong>Note:</strong> Points are based on Weight Watchers SmartPoints formula estimates. For precise tracking, always verify in your WW app. Individual results may vary based on your personal plan.
    </p>
  </div>
</div>

<script define:vars={{ calcData }}>
  function updateWW() {
    const bun = document.getElementById('ww-bun').checked;
    const ketchup = document.getElementById('ww-ketchup').checked;
    const mustard = document.getElementById('ww-mustard').checked;
    const relish = document.getElementById('ww-relish').checked;
    const onions = document.getElementById('ww-onions').checked;

    const base = bun ? calcData.baseHotDog : calcData.baseHotDogNoBun;
    let addons = 0;
    if (ketchup) addons += calcData.ketchup;
    if (mustard) addons += calcData.mustard;
    if (relish) addons += calcData.relish;
    if (onions) addons += calcData.onions;

    const total = base + addons;
    const baseReference = calcData.baseHotDog;
    const delta = total - baseReference;

    document.getElementById('ww-total').textContent = total;
    document.getElementById('ww-base-display').textContent = base + ' pts';
    document.getElementById('ww-addons').textContent = addons + ' pts';
    document.getElementById('ww-grand').textContent = total + ' pts';

    const deltaEl = document.getElementById('ww-delta');
    if (delta === 0) {
      deltaEl.textContent = 'Base value';
      deltaEl.className = 'text-sm text-blue-600 mt-1';
    } else if (delta > 0) {
      deltaEl.textContent = '+' + delta + ' from base';
      deltaEl.className = 'text-sm text-red-600 mt-1';
    } else {
      deltaEl.textContent = delta + ' from base';
      deltaEl.className = 'text-sm text-green-600 mt-1';
    }
  }

  ['ww-bun', 'ww-ketchup', 'ww-mustard', 'ww-relish', 'ww-onions'].forEach(id => {
    document.getElementById(id)?.addEventListener('change', updateWW);
  });
  updateWW();
</script>
