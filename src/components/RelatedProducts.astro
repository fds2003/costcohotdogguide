---
import affiliateData from '../data/affiliate.json';

export interface Props {
  category?: 'Health' | 'Kitchen' | 'Outdoor' | 'Food';
  scenario?: 'home-cooking' | 'picnic' | 'storage' | 'bulk-buy' | 'meal-prep';
  title?: string;
  maxItems?: number;
}

const { category, scenario, title = 'Recommended Products', maxItems = 3 } = Astro.props;

const products = affiliateData.products.filter(p => {
  const link = affiliateData.links[p.linkKey as keyof typeof affiliateData.links];
  if (!link) return false;
  const l = link as any;
  if (category && l.category !== category) return false;
  if (scenario) {
    const scenarios: string[] = l.scenario || [];
    if (!scenarios.includes(scenario)) return false;
  }
  return true;
});

const displayProducts = products.slice(0, maxItems);

function buildAffiliateUrl(linkKey: string): string {
  const link = affiliateData.links[linkKey as keyof typeof affiliateData.links];
  if (!link) return '#';
  const l = link as any;
  return `${l.url}&tag=${l.tag}`;
}
---

{displayProducts.length > 0 && (
  <section class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 my-8">
    <h3 class="text-lg font-bold text-red-800 mb-4 flex items-center">
      <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
      {title}
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {displayProducts.map(product => {
        const link = affiliateData.links[product.linkKey as keyof typeof affiliateData.links] as any;
        const category = link?.category || 'General';
        return (
          <a
            href={buildAffiliateUrl(product.linkKey)}
            target="_blank"
            rel="noopener sponsored"
            class="block bg-white rounded-lg shadow-sm border border-gray-200 hover:shadow-md hover:border-red-300 transition group"
            data-affiliate-id={product.linkKey}
            data-affiliate-category={category}
            onclick="
              if (typeof gtag !== 'undefined') {
                gtag('event', 'affiliate_click', {
                  link_id: this.dataset.affiliateId,
                  category: this.dataset.affiliateCategory
                });
              }
            "
          >
            <div class="p-4">
              <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mb-3 group-hover:bg-red-200 transition">
                <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
              </div>
              <h4 class="font-semibold text-gray-900 group-hover:text-red-700 transition">{product.title}</h4>
              <p class="text-sm text-gray-600 mt-1 line-clamp-2">{product.description}</p>
              <div class="flex items-center justify-between mt-3">
                <span class="text-sm font-medium text-green-700">{product.priceRange}</span>
                <span class="text-xs text-red-600 font-medium group-hover:underline">View on Amazon &rarr;</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
    <p class="text-xs text-gray-500 mt-4">{affiliateData.disclaimer}</p>
  </section>
)}
