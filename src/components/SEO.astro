---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  type?: 'website' | 'article' | 'faq' | 'howto' | 'review';
  publishedAt?: string;
  modifiedAt?: string;
  image?: string;
  faqData?: Array<{ question: string; answer: string }>;
  articleSchema?: {
    headline?: string;
    author?: string;
    datePublished?: string;
    dateModified?: string;
  };
  breadcrumbs?: Array<{ name: string; href: string }>;
}

const {
  title,
  description,
  canonical,
  type = 'website',
  publishedAt,
  modifiedAt,
  image = '/og-image.jpg',
  faqData,
  articleSchema,
  breadcrumbs: customBreadcrumbs
} = Astro.props;

const siteName = 'Costco Hot Dog Guide';
const siteUrl = 'https://costcohotdogguide.com';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const fullImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
const fullCanonical = canonical || `${siteUrl}${Astro.url.pathname}`;

// Auto-generate breadcrumbs from URL path
const segmentLabels: Record<string, string> = {
  'hot-dog': 'Hot Dog',
  'faq': 'FAQ',
  'tutorials': 'Tutorials',
  'ingredients': 'Ingredients',
  'nutrition': 'Nutrition',
  'cooking': 'Cooking',
  'articles': 'Articles',
  'reviews': 'Reviews',
  'menu': 'Menu',
  'data': 'Data',
  'business': 'Business',
  'guides': 'Guides',
  'savings': 'Savings',
  'tools': 'Tools',
};

const pathname = Astro.url.pathname.replace(/\/$/, '');
const segments = pathname.split('/').filter(Boolean);

const autoBreadcrumbs = segments.length === 0 ? [] : [
  { name: 'Home', href: '/' },
  ...segments.map((seg, i) => {
    const isLast = i === segments.length - 1;
    const name = isLast ? title : (segmentLabels[seg] || seg.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()));
    const href = '/' + segments.slice(0, i + 1).join('/') + '/';
    return { name, href };
  })
];

const breadcrumbs = customBreadcrumbs || autoBreadcrumbs;

const breadcrumbSchema = breadcrumbs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    ...breadcrumbs.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.name,
      "item": `${siteUrl}${item.href}`
    }))
  ]
} : null;

// Note: Do not emit top-level @type Review without itemReviewed — it triggers GSC "Review snippets" errors.
// Review pages use Article here; product Review markup lives in ReviewLayout (Product + review).
let structuredData: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': type === 'article' || type === 'review' ? 'Article' : type === 'faq' ? 'FAQPage' : type === 'howto' ? 'HowTo' : 'WebSite',
};

if (type === 'article' || type === 'review') {
  structuredData = {
    ...structuredData,
    headline: articleSchema?.headline || title,
    description,
    url: fullCanonical,
    image: fullImage,
    datePublished: articleSchema?.datePublished || publishedAt,
    dateModified: articleSchema?.dateModified || modifiedAt || publishedAt,
    author: {
      '@type': 'Organization',
      name: articleSchema?.author || siteName
    },
    publisher: {
      '@type': 'Organization',
      name: siteName,
      logo: {
        '@type': 'ImageObject',
        url: `${siteUrl}/logo.png`
      }
    }
  };
}

// Enhance WebSite type with name, url, and SearchAction on homepage
if (type === 'website') {
  structuredData.name = siteName;
  structuredData.url = siteUrl;
  if (pathname === '') {
    structuredData.potentialAction = {
      '@type': 'SearchAction',
      target: `${siteUrl}/?q={search_term_string}`,
      'query-input': 'required name=search_term_string'
    };
  }
}

if (type === 'faq' && faqData) {
  structuredData.mainEntity = faqData.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }));
}

// Generate separate FAQPage schema when article pages also have FAQ data
const faqSchemaString = (type === 'article' && faqData && faqData.length > 0)
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqData.map(item => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer
        }
      }))
    })
  : null;

const structuredDataString = JSON.stringify(structuredData);
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={fullCanonical} />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type === 'article' || type === 'review' ? 'article' : 'website'} />
<meta property="og:url" content={fullCanonical} />
<meta property="og:image" content={fullImage} />
<meta property="og:site_name" content={siteName} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImage} />

<title>{fullTitle}</title>

<!-- Structured Data: Page Type -->
<script type="application/ld+json" set:html={structuredDataString} />
{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
{faqSchemaString && <script type="application/ld+json" set:html={faqSchemaString} />}
