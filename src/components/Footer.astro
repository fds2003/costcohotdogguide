---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="text-white font-bold text-lg mb-4">
          <span class="text-yellow-400">COSTCO</span>GUIDE
        </h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Your independent guide to Costco products, prices, and the legendary $1.50 hot dog. We help shoppers make informed decisions.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">Explore</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/guide/" class="hover:text-yellow-400 transition">Hot Dog Guide</a></li>
          <li><a href="/reviews/" class="hover:text-yellow-400 transition">Product Reviews</a></li>
          <li><a href="/guides/" class="hover:text-yellow-400 transition">Shopping Guides</a></li>
          <li><a href="/savings/" class="hover:text-yellow-400 transition">Savings Tools</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-white font-semibold mb-4">Legal</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacy-policy/" class="hover:text-yellow-400 transition">Privacy Policy</a></li>
          <li><a href="/about/" class="hover:text-yellow-400 transition">About Us</a></li>
          <li><a href="/contact/" class="hover:text-yellow-400 transition">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm text-gray-500">
      <p class="mb-2">&copy; {currentYear} Costco Hot Dog Guide. All rights reserved.</p>
      <p class="text-xs text-gray-600 max-w-2xl mx-auto">
        As an Amazon Associate, we earn from qualifying purchases. This site is not affiliated with Costco Wholesale.
      </p>
    </div>
  </div>
</footer>
