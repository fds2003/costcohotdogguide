---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';

const products = [
  { name: 'Thomasville Modular Sectional', price: '$1,299', rating: 4.5, pros: ['Modular design', 'High-quality fabric', 'Easy assembly'], cons: ['Long lead time', 'Large footprint'] },
  { name: 'Bayside Furnishings Writing Desk', price: '$249', rating: 4.3, pros: ['Solid wood top', 'Built-in USB ports', 'Compact design'], cons: ['Assembly required', 'Limited color options'] },
  { name: 'Pike & Main Accent Chair', price: '$189', rating: 4.2, pros: ['Stylish design', 'Comfortable cushion', 'Good lumbar support'], cons: ['Faux leather may peel over time'] },
];

const publishedAt = '2026-04-29';
const modifiedAt = '2026-04-29';
---

<BaseLayout
  title="Best Furniture Deals at Costco"
  description="Independent reviews of the best furniture deals at Costco. Sofas, desks, chairs, and more with honest pros and cons."
  type="review"
  publishedAt={publishedAt}
  modifiedAt={modifiedAt}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-8">
      <p class="text-sm text-yellow-800">
        <strong>Disclosure:</strong> As an Amazon Associate, we earn from qualifying purchases.
      </p>
    </div>

    <h1 class="text-4xl font-bold text-gray-900 mb-4">Best Furniture Deals at Costco</h1>
    <p class="text-lg text-gray-600 mb-8">Costco furniture offers surprising quality at warehouse prices. We tested and reviewed the best pieces for every room in your home.</p>

    <div class="space-y-6 mb-10">
      {products.map(p => (
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-4">
            <div>
              <h2 class="text-xl font-bold text-gray-900">{p.name}</h2>
              <div class="flex items-center mt-1">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class={`w-5 h-5 ${i < Math.floor(p.rating) ? 'text-yellow-400' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
                <span class="ml-2 text-gray-600">{p.rating}/5</span>
              </div>
            </div>
            <span class="text-2xl font-bold text-green-700 mt-2 md:mt-0">{p.price}</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <p class="text-sm font-semibold text-green-700 mb-1">Pros</p>
              <ul class="list-disc list-inside text-sm text-gray-600">
                {p.pros.map(pro => <li>{pro}</li>)}
              </ul>
            </div>
            <div>
              <p class="text-sm font-semibold text-red-700 mb-1">Cons</p>
              <ul class="list-disc list-inside text-sm text-gray-600">
                {p.cons.map(con => <li>{con}</li>)}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Verdict</h2>
    <p class="text-gray-700 mb-8">Costco furniture is ideal for shoppers who want solid quality without the boutique markup. The modular sectional is particularly impressive for the price point. If you are furnishing a home office, the Bayside desk is a standout value with its integrated charging features.</p>

    <RelatedProducts category="Kitchen" title="Home Organization Picks" />
  </article>
</BaseLayout>
