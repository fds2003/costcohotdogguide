---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';
import RelatedContent from '../../components/RelatedContent.astro';

const appliances = [
  { name: 'Ninja Air Fryer Pro XL', price: '$89', rating: 4.6, bestFor: 'Hot dogs, fries, quick meals', why: 'Even heating, easy cleanup' },
  { name: 'Vitamix E320', price: '$299', rating: 4.8, bestFor: 'Smoothies, soups, sauces', why: 'Commercial-grade power at Costco price' },
  { name: 'KitchenAid Stand Mixer', price: '$279', rating: 4.7, bestFor: 'Baking, dough, mixing', why: 'Iconic durability, Costco bundle includes attachments' },
];
---

<BaseLayout
  title="Best Kitchen Appliances at Costco"
  description="Best kitchen appliances at Costco: air fryers, blenders, mixers reviewed. Cook Costco hot dogs perfectly at home with the right gear."
  type="review"
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-8">
      <p class="text-sm text-yellow-800"><strong>Disclosure:</strong> As an Amazon Associate, we earn from qualifying purchases.</p>
    </div>
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Best Kitchen Appliances at Costco</h1>
    <p class="text-lg text-gray-600 mb-8">Costco's kitchen appliance selection offers exceptional value. Here are our top picks.</p>

    <div class="space-y-6 mb-10">
      {appliances.map(a => (
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-3">
            <h2 class="text-xl font-bold text-gray-900">{a.name}</h2>
            <span class="text-2xl font-bold text-green-700 mt-1 md:mt-0">{a.price}</span>
          </div>
          <p class="text-gray-600 mb-2"><strong>Best for:</strong> {a.bestFor}</p>
          <p class="text-gray-600"><strong>Why we like it:</strong> {a.why}</p>
          <div class="flex items-center mt-3">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg class={`w-5 h-5 ${i < Math.floor(a.rating) ? 'text-yellow-400' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <span class="ml-2 text-gray-600">{a.rating}/5</span>
          </div>
        </div>
      ))}
    </div>

    <RelatedProducts category="Kitchen" title="Top Kitchen Deals on Amazon" />
    <RelatedContent currentPage="/reviews/kitchen-appliances/" />
  </article>
</BaseLayout>
