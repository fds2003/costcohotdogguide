---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Costco Data & Insights | Price Maps, Nutrition, Crowd Predictions"
  description="Interactive data visualizations for Costco shoppers. Compare prices across states, analyze nutrition facts, and find the best times to visit."
  type="website"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Data & Insights</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Interactive tools and data visualizations to help you shop smarter at Costco.
      </p>
    </div>

    <!-- Data Pages Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/data/price-map/" class="group bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-lg hover:border-red-300 transition">
        <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-green-200 transition">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 group-hover:text-red-700 transition">Price Map</h3>
        <p class="text-gray-600 mt-2">See how hot dog prices compare across all 50 US states and international locations.</p>
      </a>

      <a href="/data/nutrition-comparison/" class="group bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-lg hover:border-red-300 transition">
        <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-200 transition">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 group-hover:text-red-700 transition">Nutrition Comparison</h3>
        <p class="text-gray-600 mt-2">Interactive charts comparing calories, protein, fat, and sodium across the full menu.</p>
      </a>

      <a href="/data/crowd-prediction/" class="group bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-lg hover:border-red-300 transition">
        <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-orange-200 transition">
          <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 group-hover:text-red-700 transition">Crowd Prediction</h3>
        <p class="text-gray-600 mt-2">Plan your visit with our crowd heatmap. Find the best times to avoid long lines.</p>
      </a>
    </div>
  </div>
</BaseLayout>
