---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqData = [
  {
    question: "Does Costco hot dog come with a drink?",
    answer: "Yes. The $1.50 combo includes a 20 oz soda with free refills."
  },
  {
    question: "Can you get a different drink?",
    answer: "Most locations offer Pepsi products. Some newer locations may have Coca-Cola products depending on regional contracts."
  }
];
---

<BaseLayout
  title="Does Costco Hot Dog Come With a Drink?"
  description="Yes — the $1.50 Costco hot dog combo includes a 20 oz soda with free refills. Full details."
  type="faq"
  faqData={faqData}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-green-50 border border-green-200 rounded-xl p-8 text-center mb-10">
      <p class="text-sm text-green-700 font-medium uppercase tracking-wide">Answer</p>
      <p class="text-4xl font-bold text-green-800 mt-2">Yes</p>
      <p class="text-green-700 mt-2">20 oz soda with free refills</p>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 mb-4">Does Costco Hot Dog Come With a Drink?</h1>
    <p class="text-gray-600 mb-8">Everything included in the famous $1.50 combo.</p>
    <h2 class="text-xl font-bold text-gray-900 mb-3">What's Included</h2>
    <p class="text-gray-700 mb-6">The $1.50 combo includes: one quarter-pound all-beef hot dog in a steamed bun, plus a 20 oz fountain soda with unlimited free refills. That's it — no upgrades, no substitutions, just unbeatable value.</p>
    <h2 class="text-xl font-bold text-gray-900 mb-3">Drink Options</h2>
    <p class="text-gray-700 mb-6">Most Costco food courts serve Pepsi products including Pepsi, Diet Pepsi, Mountain Dew, and Sierra Mist. Some newer locations in certain regions may carry Coca-Cola products. All locations offer free refills.</p>
  </article>
</BaseLayout>
