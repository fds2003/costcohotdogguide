---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  {
    category: "Dietary Restrictions",
    questions: [
      { q: "Are Costco hot dogs gluten free?", href: "/hot-dog/gluten-free/", keyword: "gluten free" },
      { q: "Are Costco hot dogs dairy free?", href: "/faq/dairy-free-buns/", keyword: "dairy free" },
      { q: "Are Costco hot dogs vegan?", href: "/hot-dog/vegan/", keyword: "vegan" },
      { q: "Are Costco hot dogs soy free?", href: "/faq/soy-free/", keyword: "soy free" },
    ]
  },
  {
    category: "Ingredients",
    questions: [
      { q: "Does Costco hot dog have pork?", href: "/ingredients/beef-or-pork/", keyword: "pork" },
      { q: "Are Costco hot dogs all beef?", href: "/ingredients/brand/", keyword: "all beef" },
      { q: "Do Costco hot dogs have MSG?", href: "/faq/msg/", keyword: "msg" },
      { q: "Do Costco hot dogs have nitrates?", href: "/hot-dog/sodium/", keyword: "nitrates" },
    ]
  },
  {
    category: "Religious & Cultural",
    questions: [
      { q: "Is Costco hot dog kosher?", href: "/faq/kosher/", keyword: "kosher" },
      { q: "Are Costco hot dogs halal?", href: "/faq/halal/", keyword: "halal" },
    ]
  },
  {
    category: "Other Common Questions",
    questions: [
      { q: "How big is a Costco hot dog?", href: "/faq/how-big/", keyword: "size" },
      { q: "Can you buy a Costco hot dog without a membership?", href: "/faq/without-membership/", keyword: "membership" },
      { q: "Does the Costco hot dog come with a drink?", href: "/faq/with-drink/", keyword: "drink" },
      { q: "Is the Costco hot dog beef or pork?", href: "/ingredients/beef-or-pork/", keyword: "beef or pork" },
    ]
  },
];
---

<BaseLayout
  title="Costco Hot Dog FAQ — All Your Questions Answered"
  description="Find answers to all your Costco hot dog questions: gluten free, dairy free, kosher, halal, ingredients, nitrates, and more."
  type="website"

  canonical="https://costcohotdogguide.com/faq/">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 mb-4">
        <span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>
        Trust & Awareness Layer
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Costco Hot Dog FAQ</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Get clear, research-backed answers to the most common questions about Costco's famous $1.50 hot dog.
      </p>
    </div>

    <!-- Search -->
    <div class="max-w-xl mx-auto mb-12">
      <div class="relative">
        <input
          type="text"
          id="faq-search"
          placeholder="Search questions..."
          class="w-full px-5 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition"
        />
        <svg class="w-5 h-5 text-gray-400 absolute right-4 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </div>

    <!-- FAQ Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="faq-grid">
      {faqs.map(group => (
        <div class="faq-category bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
          <div class="bg-blue-50 px-6 py-4 border-b border-blue-100">
            <h2 class="text-lg font-bold text-blue-900">{group.category}</h2>
          </div>
          <div class="p-4">
            <ul class="space-y-2">
              {group.questions.map(item => (
                <li class="faq-item">
                  <a
                    href={item.href}
                    class="block px-4 py-3 rounded-lg hover:bg-blue-50 transition group"
                  >
                    <div class="flex items-center justify-between">
                      <span class="text-gray-700 group-hover:text-blue-700 font-medium">{item.q}</span>
                      <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-500 flex-shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center bg-blue-50 border border-blue-200 rounded-xl p-8">
      <h3 class="text-xl font-bold text-blue-900 mb-2">Want to learn more?</h3>
      <p class="text-gray-600 mb-4">Explore our guides on nutrition, cooking, and ingredients.</p>
      <a
        href="/tutorials/"
        class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
        onclick="if(typeof gtag!=='undefined')gtag('event','funnel_progression',{from_stage:'A',to_stage:'B',link_text:'FAQ CTA'});"
      >
        Browse Tutorials
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>

  <script is:inline>
    (function() {
      const searchInput = document.getElementById('faq-search');
      const faqItems = document.querySelectorAll('.faq-item');
      const categories = document.querySelectorAll('.faq-category');

      searchInput?.addEventListener('input', function(e) {
        const query = e.target.value.toLowerCase();
        faqItems.forEach(item => {
          const text = item.textContent.toLowerCase();
          item.style.display = text.includes(query) ? 'block' : 'none';
        });
        categories.forEach(cat => {
          const visibleItems = cat.querySelectorAll('.faq-item[style*="block"], .faq-item:not([style*="none"])');
          cat.style.display = visibleItems.length > 0 ? 'block' : 'none';
        });
      });
    })();
  </script>
</BaseLayout>
