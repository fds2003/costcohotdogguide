---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  { q: "Are Costco hot dogs all beef?", a: "Yes. Costco hot dogs are 100% USDA Choice beef with no fillers, poultry, or pork.", href: "/faq/beef/" },
  { q: "How many calories in a Costco hot dog?", a: "Approximately 570 calories with the bun, or 370 calories without.", href: "/nutrition/calories/" },
  { q: "Can you buy without a membership?", a: "In most US locations, yes. Food courts are generally open to the public.", href: "/faq/without-membership/" },
  { q: "Are the buns dairy free?", a: "Yes. The buns contain no milk, butter, or dairy-derived ingredients.", href: "/dietary/dairy-free/" },
  { q: "Are they gluten free?", a: "No. The bun contains wheat flour.", href: "/dietary/gluten-free/" },
  { q: "Does Costco hot dog have pork?", a: "No. They are 100% beef.", href: "/faq/pork/" },
  { q: "Do they come with a drink?", a: "Yes. The $1.50 combo includes a 20 oz soda with free refills.", href: "/faq/with-drink/" },
  { q: "How big is a Costco hot dog?", a: "It's a quarter-pound hot dog (approximately 4 oz / 113g).", href: "/faq/how-big/" },
  { q: "Are they halal?", a: "Not officially certified halal.", href: "/dietary/halal/" },
  { q: "Are they kosher?", a: "Not officially certified kosher.", href: "/dietary/kosher/" },
  { q: "Do they have nitrates?", a: "Yes. Sodium nitrite is used as a preservative.", href: "/dietary/nitrates/" },
  { q: "Can you cook them at home?", a: "Yes. You can boil, grill, air fry, or pan-fry Costco hot dogs.", href: "/cooking/at-home/" },
];

const faqSchemaData = faqs.map(f => ({ question: f.q, answer: f.a }));
---

<BaseLayout
  title="Costco Hot Dog FAQ"
  description="Quick answers to the most common questions about Costco hot dogs. Calories, ingredients, dietary info, and more."
  type="faq"
  faqData={faqSchemaData}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h1>
    <p class="text-lg text-gray-600 mb-8">Quick answers to the most common questions about Costco's $1.50 hot dog.</p>

    <div class="space-y-4">
      {faqs.map(item => (
        <details class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden group">
          <summary class="px-6 py-4 font-semibold text-gray-900 cursor-pointer hover:bg-gray-50 transition flex justify-between items-center">
            {item.q}
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-4 text-gray-600">
            <p>{item.a}</p>
            <a href={item.href} class="text-red-700 text-sm font-medium hover:underline mt-2 inline-block">Read full article &rarr;</a>
          </div>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>
