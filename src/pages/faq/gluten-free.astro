const question = "Are Costco hot dogs gluten free?";
const answer = "No, Costco's food court hot dogs are not gluten free. While the hot dog itself (the meat) contains no gluten ingredients, it is served in a wheat-based bun, and cross-contamination is highly likely in the food court preparation area.";
---

<FAQLayout
  title={question}
  description={answer}
  question={question}
  answer={answer}
  targetKeyword="are costco hot dogs gluten free"
  relatedQuestions={[
    "Do Costco hot dogs have wheat?",
    "Are Costco hot dog buns gluten free?",
    "What allergens are in Costco hot dogs?"
  ]}
  learnMoreLinks={[
    { title: "Costco Hot Dog Ingredients", href: "/ingredients/ingredients-list/", description: "Full breakdown of all ingredients in Costco hot dogs and buns." },
    { title: "Dietary Information", href: "/dietary/", description: "Complete guide to allergens and dietary considerations." }
