---
import BaseLayout from '../../layouts/BaseLayout.astro';

const guides = [
  {
    title: 'How to Maximize Your Costco Membership',
    description: 'Tips and tricks to get the most value from your $60-$120 annual membership fee.',
    href: '/guides/maximize-membership/',
    readTime: '8 min read'
  },
  {
    title: 'Costco vs Amazon: Where to Buy What',
    description: 'Side-by-side comparison of prices, selection, and convenience for popular product categories.',
    href: '/guides/costco-vs-amazon/',
    readTime: '10 min read'
  },
  {
    title: 'Kirkland Brand vs Name Brand',
    description: 'Which Kirkland Signature products beat the name brands? A detailed comparison.',
    href: '/guides/kirkland-vs-name-brand/',
    readTime: '12 min read'
  },
  {
    title: 'The Complete Costco Shopping Strategy',
    description: 'How to shop smart, avoid impulse buys, and find the real deals.',
    href: '/guides/shopping-strategy/',
    readTime: '7 min read'
  }
];
---

<BaseLayout
  title="Costco Shopping Guides"
  description="Expert tips and strategies for shopping at Costco. Maximize savings, compare products, and shop smarter."
  type="website"
>
  <section class="bg-red-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Shopping Guides</h1>
      <p class="text-xl text-red-100 max-w-2xl">Expert strategies to help you shop smarter, save more, and get the most out of every Costco trip.</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="space-y-6">
      {guides.map(guide => (
        <a href={guide.href} class="block bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-lg hover:border-red-300 transition">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between">
            <div>
              <h2 class="text-xl font-bold text-gray-900 hover:text-red-700 transition">{guide.title}</h2>
              <p class="text-gray-600 mt-2">{guide.description}</p>
            </div>
            <div class="mt-4 md:mt-0 md:ml-6 flex items-center space-x-4">
              <span class="text-sm text-gray-500">{guide.readTime}</span>
              <span class="text-red-700 font-medium">Read &rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 bg-yellow-50 border border-yellow-200 rounded-xl p-6 text-center">
      <h3 class="text-lg font-bold text-gray-900 mb-2">Want our best tips delivered?</h3>
      <p class="text-gray-600 mb-4">Get exclusive Costco shopping strategies and deal alerts.</p>
      <a href="/savings/" class="inline-block bg-red-700 text-white font-semibold px-6 py-3 rounded-lg hover:bg-red-600 transition">
        Explore Savings Tools
      </a>
    </div>
  </div>
</BaseLayout>
