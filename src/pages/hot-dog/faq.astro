---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';

const funnelStage = 'A';

/** Each item: visible short answer + detail; FAQPage answer aligns with stripped visible text (no markup). */
const faqItems = [
  {
    id: 'kosher',
    question: 'Is Costco hot dog kosher?',
    short:
      'No. Costco\'s Kirkland Signature all-beef hot dog is not certified kosher.',
    detail:
      'It is beef-based, but without rabbinical certification and standard cross-contact controls, it doesn\'t meet kosher labeling. Observant buyers should rely on kosher-certified brands instead.',
    moreHref: '/faq/kosher/',
    moreLabel: 'Kosher FAQ',
  },
  {
    id: 'sodium',
    question: 'How much sodium is in a Costco hot dog?',
    short:
      'About 1,700mg sodium for the combo (hot dog with bun)—roughly 74% of a 2,300mg daily limit.',
    detail:
      'Individual meals vary slightly by toppings and buns from different bakeries; people on low-sodium diets should skip condiments high in salt and confirm current labels at the kiosk.',
    moreHref: '/hot-dog/sodium/',
    moreLabel: 'full sodium breakdown',
  },
  {
    id: 'bun-dairy',
    question: 'Does the Costco hot dog bun contain dairy?',
    short:
      'Typically no intentional dairy in the enriched wheat bun, but formulations can vary by supplier and region.',
    detail:
      'Ingredient lists printed on packs or kiosk displays are the authoritative source—check for milk powder or whey before assuming dairy-free.',
    moreHref: '/faq/dairy-free-buns/',
    moreLabel: 'dairy-free bun notes',
  },
  {
    id: 'cooking',
    question: 'How does Costco cook hot dogs?',
    short:
      'Food-court stands usually heat rollers or similar equipment for fast throughput; specifics vary slightly by warehouse.',
    detail:
      'At home you can grill, boil, or air fry using our <a href="/tutorials/air-fryer/" class="text-red-700 underline font-medium">air fryer tutorial</a> for texture similar to rollers.',
    moreHref: '/hot-dog/cooking-at-home/',
    moreLabel: 'cooking at home',
  },
  {
    id: 'ingredients-source',
    question: 'Where do Costco hot dog ingredients come from?',
    short:
      'The frank is Kirkland Signature 100% beef; Costco emphasizes vertical integration and large-scale contracting for buns and toppings.',
    detail:
      'Exact supplier lines can rotate; packaging and regional listings remain the reliable reference for allergens and additives.',
    moreHref: '/ingredients/',
    moreLabel: 'ingredients hub',
  },
  {
    id: 'calories',
    question: 'How many calories are in a Costco hot dog?',
    short:
      'Roughly 570 calories for hot dog plus bun (~360 frank only; ~210 bun).',
    detail:
      'Drinks add 150–200+ calories depending on fountain choice; see year-by-year context on our <a href="/hot-dog/calories/" class="text-red-700 underline font-medium">calories page</a>.',
    moreHref: '/hot-dog/calories/',
    moreLabel: 'calories & comparison',
  },
  {
    id: 'safety',
    question: 'Can everyone eat Costco hot dogs safely?',
    short:
      'Most diners can—but avoid or modify them if you have wheat allergy, celiac disease, sodium limits, or other strict dietary rules.',
    detail:
      'Nitrites, sodium, and processed meat intake should follow your clinician\'s advice; moderation matters for cardiovascular health.',
    moreHref: '/hot-dog/nutrition/',
    moreLabel: 'nutrition facts',
  },
];

const faqData = faqItems.map(({ question, short, detail }) => ({
  question,
  answer: `${short} ${detail.replace(/<[^>]*>/g, '')}`,
}));

---

<BaseLayout
  title="Costco Hot Dog FAQ: Kosher? Sodium? Bun Dairy? (Direct Answers)"
  description="Straight answers about Costco hot dogs: kosher status, sodium, bun dairy, how they’re cooked, and ingredients—plus links to calories, sodium, and full nutrition."
  type="article"
  publishedAt="2026-04-29"
  modifiedAt="2026-05-08"
  faqData={faqData}
>
  <!-- Consider merging content or using 301 redirect to avoid cannibalization -->

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Costco Hot Dog Frequently Asked Questions</h1>
    <p class="text-lg text-gray-600 mb-8">
      Each question opens with a one-line answer, then expands with nuance—so SERP skim readers and planners both get value.
    </p>

    <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Popular questions</h2>
    <div class="space-y-6">
      {
        faqItems.map(({ id, question, short, detail, moreHref, moreLabel }) => (
          <div id={id} class="rounded-lg border border-gray-200 bg-gray-50 p-5 md:p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{question}</h3>
            <p class="text-gray-900 font-semibold leading-snug">{short}</p>
            <p class="text-gray-700 mt-3 leading-relaxed" set:html={detail} />
            <p class="mt-3 text-sm">
              <a href={moreHref} class="text-red-700 font-medium hover:underline">
                Deep dive → {moreLabel}
              </a>
            </p>
          </div>
        ))
      }
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mt-12 mb-4">Nutrition &amp; sourcing context</h2>
    <p class="text-gray-700 leading-relaxed mb-4">
      Costco posts nutrition where available—USDA{' '}
      <a href="https://fdc.nal.usda.gov/" class="text-red-700 underline" rel="noopener noreferrer" target="_blank">FoodData Central</a>
      {' '}and package labels complement what we summarize here.
    </p>

    <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Related Guides</h2>
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-8">
      <p class="text-gray-700 mb-3">Explore more:</p>
      <div class="flex flex-wrap gap-3">
        <a href="/hot-dog/calories/" class="text-blue-600 hover:text-blue-800 underline">calories</a>
        <a href="/hot-dog/nutrition/" class="text-blue-600 hover:text-blue-800 underline">nutrition facts</a>
      </div>
    </div>

    <RelatedContent currentPage="/hot-dog/faq/" />

    <div class="mt-12">
      <RelatedProducts funnelStage={funnelStage as 'A'} />
    </div>
  </article>
</BaseLayout>
