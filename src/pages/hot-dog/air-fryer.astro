  publishedAt="2026-04-29"
  faqData={[{"question":"How long do I cook a Costco hot dog in an air fryer?","answer":"Cook at 375°F (190°C) for 6-8 minutes, turning halfway through. For extra crispiness, cook for 8-9 minutes."},{"question":"Can I cook frozen hot dogs?","answer":"Yes, add 2-3 extra minutes to the cooking time. For best results, thaw first, but air fryers handle frozen hot dogs well."}]}
