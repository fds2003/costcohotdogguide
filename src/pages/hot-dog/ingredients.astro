---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';

const keywordCore = "costco hot dog ingredients";
const keywordVariants = ["What is in a Costco hot dog?", "Are there allergens in Costco hot dogs?"];
const topicCluster = "hot-dog";
const funnelStage = "A";
---

<BaseLayout
  title="Costco Hot Dog Ingredients | What's Inside"
  description="Full list of Costco hot dog ingredients including meat type, bun components, additives, preservatives, and allergen information."
  type="article"
  publishedAt="2026-04-29"
  faqData={[{"question":"What is in a Costco hot dog?","answer":"Costco hot dogs contain beef, water, corn syrup, salt, spices, garlic powder, and sodium nitrite. The bun contains enriched wheat flour, water, sugar, yeast, and vegetable oil."},{"question":"Are there allergens in Costco hot dogs?","answer":"Yes, the bun contains wheat (gluten). The hot dog itself may contain traces of soy. Cross-contamination with dairy is possible in the food court."}]}
>
  <!-- CONFLICT WARNING: This page overlaps with existing content at /ingredients/ingredients-list/ -->
  <!-- Consider merging content or using 301 redirect to avoid cannibalization -->
  <link rel="canonical" href="https://costcohotdogguide.com/ingredients/ingredients-list/" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is in a Costco hot dog?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Costco hot dogs contain beef, water, corn syrup, salt, spices, garlic powder, and sodium nitrite. The bun contains enriched wheat flour, water, sugar, yeast, and vegetable oil."
        }
      },
      {
        "@type": "Question",
        "name": "Are there allergens in Costco hot dogs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, the bun contains wheat (gluten). The hot dog itself may contain traces of soy. Cross-contamination with dairy is possible in the food court."
        }
      }
    ]
  })} />

