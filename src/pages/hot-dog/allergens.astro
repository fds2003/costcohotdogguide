---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';

const keywordCore = "costco hot dog allergen";
const keywordVariants = ["Does Costco hot dog contain allergens?", "Is it safe for people with food allergies?"];
const topicCluster = "hot-dog";
const funnelStage = "A";
---

<BaseLayout
  title="Costco Hot Dog Allergens | Dairy, Soy, Gluten & More"
  description="Complete allergen information for Costco hot dogs. Common allergens, kosher info, and tips for people with food sensitivities."
  type="article"
  publishedAt="2026-04-29"
  faqData={[{"question":"Does Costco hot dog contain allergens?","answer":"The bun contains wheat (gluten). The hot dog may contain traces of soy. Dairy cross-contamination is possible in food court preparation areas."},{"question":"Is it safe for people with food allergies?","answer":"People with wheat allergies or celiac disease should avoid the bun. Those with soy allergies should exercise caution. Always ask staff about preparation practices."}]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Does Costco hot dog contain allergens?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The bun contains wheat (gluten). The hot dog may contain traces of soy. Dairy cross-contamination is possible in food court preparation areas."
        }
      },
      {
        "@type": "Question",
        "name": "Is it safe for people with food allergies?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "People with wheat allergies or celiac disease should avoid the bun. Those with soy allergies should exercise caution. Always ask staff about preparation practices."
        }
      }
    ]
  })} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Costco Hot Dog Allergen Information</h1>
    <p class="text-lg text-gray-600 mb-8">Complete allergen information for Costco hot dogs. Common allergens, kosher info, and tips for people with food sensitivities.</p>

  <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Common Allergens</h2>
    <h3 class="text-xl font-semibold text-gray-800 mt-6 mb-3">Dairy, Soy, Gluten</h3>
    <p class="text-gray-700 leading-relaxed mb-4">[Content about Dairy, Soy, Gluten goes here. Expand with details, data, and insights.]</p>

  <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Kosher & Dietary Info</h2>
    <p class="text-gray-700 leading-relaxed mb-4">[Content about Kosher & Dietary Info goes here. Expand with details, data, and insights.]</p>

  <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Tips for Sensitive Diets</h2>
    <p class="text-gray-700 leading-relaxed mb-4">[Content about Tips for Sensitive Diets goes here. Expand with details, data, and insights.]</p>

    <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Related Guides</h2>
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-8">
      <p class="text-gray-700 mb-3">Explore more about Costco hot dogs:</p>
      <div class="flex flex-wrap gap-3">
    <a href="/hot-dog/ingredients/" class="text-blue-600 hover:text-blue-800 underline">full ingredients list</a>
    <a href="/hot-dog/healthy/" class="text-blue-600 hover:text-blue-800 underline">dietary guides</a>
      </div>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-gray-50 rounded-lg p-5">
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Does Costco hot dog contain allergens?</h3>
        <p class="text-gray-700">The bun contains wheat (gluten). The hot dog may contain traces of soy. Dairy cross-contamination is possible in food court preparation areas.</p>
      </div>
      <div class="bg-gray-50 rounded-lg p-5">
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Is it safe for people with food allergies?</h3>
        <p class="text-gray-700">People with wheat allergies or celiac disease should avoid the bun. Those with soy allergies should exercise caution. Always ask staff about preparation practices.</p>
      </div>
    </div>

    <div class="mt-12">
      <RelatedProducts funnelStage="A" />
    </div>
  </article>
</BaseLayout>
