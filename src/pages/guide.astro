---
import BaseLayout from '../layouts/BaseLayout.astro';
import RelatedProducts from '../components/RelatedProducts.astro';
import AdUnit from '../components/AdUnit.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

const publishedAt = '2026-04-29';
const modifiedAt = '2026-05-05';
---

<BaseLayout
  title="Costco Hot Dog Guide 2026 — Calories, Price History, Ingredients & $1.50 Combo"
  description="570-calorie breakdown, 41-year $1.50 price history, full ingredients, food-court combo facts, and links to our interactive price chart. Updated May 2026."
  type="article"
  publishedAt={publishedAt}
  modifiedAt={modifiedAt}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Costco Hot Dog: The Ultimate Guide (2026)</h1>
      <p class="text-lg text-gray-600">Everything you need to know about the most famous hot dog in America.</p>
      <div class="mt-4 text-sm text-gray-500">
        Published: <time datetime={publishedAt}>{publishedAt}</time> | Last updated: <time datetime={modifiedAt}>{modifiedAt}</time>
      </div>
    </header>

    <nav class="mb-10 not-prose rounded-xl border border-gray-200 bg-gray-50 p-4 md:p-6" aria-label="Guide sections">
      <p class="text-sm font-semibold text-gray-900 mb-3">Jump to deep dives</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 text-sm">
        <a href="/hot-dog/calories/" class="text-red-700 hover:underline font-medium">Calories (with / without bun)</a>
        <a href="/hot-dog/nutrition/" class="text-red-700 hover:underline font-medium">Full nutrition facts</a>
        <a href="/hot-dog/sodium/" class="text-red-700 hover:underline font-medium">Sodium content</a>
        <a href="/ingredients/" class="text-red-700 hover:underline font-medium">Ingredients</a>
        <a href="/hot-dog/price/" class="text-red-700 hover:underline font-medium">Price &amp; regions</a>
        <a href="/tools/price-history/" class="text-red-700 hover:underline font-medium">Interactive price history</a>
        <a href="/hot-dog/price-history/" class="text-red-700 hover:underline font-medium">Price story &amp; timeline</a>
        <a href="/faq/" class="text-red-700 hover:underline font-medium">FAQ</a>
        <a href="/menu/new/" class="text-red-700 hover:underline font-medium">Menu changes</a>
      </div>
    </nav>

    <section class="not-prose mb-10" aria-label="Core info cards">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Core Facts at a Glance</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/hot-dog/price/" class="block rounded-xl border border-green-200 bg-green-50 p-5 hover:shadow-sm transition">
          <p class="text-sm font-semibold text-green-700">Price</p>
          <p class="text-3xl font-bold text-green-900 mt-1">$1.50</p>
          <p class="text-sm text-green-800 mt-2">Unchanged combo price since 1985. See current price context.</p>
        </a>
        <a href="/hot-dog/calories/" class="block rounded-xl border border-red-200 bg-red-50 p-5 hover:shadow-sm transition">
          <p class="text-sm font-semibold text-red-700">Calories</p>
          <p class="text-3xl font-bold text-red-900 mt-1">570 cal</p>
          <p class="text-sm text-red-800 mt-2">With bun. Compare with no-bun and yearly updates.</p>
        </a>
        <a href="/ingredients/" class="block rounded-xl border border-blue-200 bg-blue-50 p-5 hover:shadow-sm transition">
          <p class="text-sm font-semibold text-blue-700">Ingredients</p>
          <p class="text-xl font-bold text-blue-900 mt-1">All-beef + bun</p>
          <p class="text-sm text-blue-800 mt-2">Quick ingredient overview, allergens, and sourcing links.</p>
        </a>
      </div>
    </section>

    <section class="not-prose mb-10 rounded-xl border border-gray-200 bg-white p-5 md:p-6" aria-label="Price history preview">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Price History Preview</h2>
      <p class="text-gray-700 mb-4">The hot dog combo has held at <strong>$1.50</strong> for over 40 years. Explore the timeline side-by-side with pizza, rotisserie chicken, and gas prices in our interactive tool.</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-gray-500">Start year</p>
          <p class="text-lg font-semibold text-gray-900">1985</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-gray-500">Current combo price</p>
          <p class="text-lg font-semibold text-gray-900">$1.50</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <p class="text-xs uppercase tracking-wide text-gray-500">View mode</p>
          <p class="text-lg font-semibold text-gray-900">Interactive chart</p>
        </div>
      </div>
      <a href="/tools/price-history/" class="inline-flex items-center justify-center rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700">查看交互式历史图表 -></a>
    </section>

    <section class="not-prose mb-10" aria-label="Popular FAQ direct answers">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Popular Questions (Direct Answers)</h2>
      <div class="space-y-4">
        <div class="rounded-lg border border-gray-200 bg-white p-4">
          <h3 class="text-lg font-semibold text-gray-900">Is Costco hot dog kosher?</h3>
          <p class="text-gray-700 mt-1">No. It is all-beef but not officially kosher certified.</p>
          <a href="/hot-dog/faq/" class="text-red-700 text-sm font-medium hover:underline mt-2 inline-block">[了解更多]</a>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-4">
          <h3 class="text-lg font-semibold text-gray-900">How much sodium is in a Costco hot dog?</h3>
          <p class="text-gray-700 mt-1">Roughly 1,700mg per hot dog with bun.</p>
          <a href="/hot-dog/faq/" class="text-red-700 text-sm font-medium hover:underline mt-2 inline-block">[了解更多]</a>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-4">
          <h3 class="text-lg font-semibold text-gray-900">Does the bun contain dairy?</h3>
          <p class="text-gray-700 mt-1">Usually no dairy, but formulas can vary by supplier and region.</p>
          <a href="/hot-dog/faq/" class="text-red-700 text-sm font-medium hover:underline mt-2 inline-block">[了解更多]</a>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-4">
          <h3 class="text-lg font-semibold text-gray-900">How are Costco hot dogs cooked?</h3>
          <p class="text-gray-700 mt-1">They are typically heated/held at food-court service equipment for fast turnover.</p>
          <a href="/hot-dog/faq/" class="text-red-700 text-sm font-medium hover:underline mt-2 inline-block">[了解更多]</a>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-4">
          <h3 class="text-lg font-semibold text-gray-900">Where are Costco hot dogs sourced?</h3>
          <p class="text-gray-700 mt-1">Kirkland all-beef supply is managed through Costco's own production system.</p>
          <a href="/hot-dog/faq/" class="text-red-700 text-sm font-medium hover:underline mt-2 inline-block">[了解更多]</a>
        </div>
      </div>
    </section>

    <div class="prose prose-lg max-w-none">
      <p class="lead text-xl text-gray-700">
        The Costco hot dog is more than just a quick meal — it's a cultural icon. Since 1985, Costco has sold its legendary hot dog and soda combo for just $1.50, and the price hasn't changed in over 40 years. This guide covers everything from nutrition facts to the business strategy behind America's cheapest lunch.
      </p>

      <div class="my-8">
        <AdUnit slot="in_content_1" type="in-article" format="auto" minHeight="250px" />
      </div>

      <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">What You Get for $1.50</h2>
      <p>
        The Costco food court hot dog combo includes a quarter-pound all-beef hot dog and a 20 oz. soda with free refills. The hot dog itself weighs approximately 4 ounces and is served in a soft, steamed bun.
      </p>
      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 my-6">
        <p class="font-semibold text-yellow-800">Key Facts</p>
        <ul class="list-disc list-inside text-yellow-800 mt-2">
          <li>Price: $1.50 (unchanged since 1985)</li>
          <li>Weight: 1/4 pound (4 oz)</li>
          <li>Meat: 100% USDA Choice beef</li>
          <li>Drink: 20 oz soda with free refills</li>
          <li>Available at: Costco food courts worldwide</li>
        </ul>
      </div>

      <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Nutrition Overview</h2>
      <p>
        A Costco hot dog with bun contains approximately 570 calories. Here's the breakdown:
      </p>
      <table class="w-full border-collapse border border-gray-300 mt-4">
        <thead>
          <tr class="bg-gray-100">
            <th class="border border-gray-300 px-4 py-2 text-left">Nutrient</th>
            <th class="border border-gray-300 px-4 py-2 text-left">Amount</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="border border-gray-300 px-4 py-2">Calories</td><td class="border border-gray-300 px-4 py-2">570</td></tr>
          <tr><td class="border border-gray-300 px-4 py-2">Total Fat</td><td class="border border-gray-300 px-4 py-2">33g</td></tr>
          <tr><td class="border border-gray-300 px-4 py-2">Saturated Fat</td><td class="border border-gray-300 px-4 py-2">12g</td></tr>
          <tr><td class="border border-gray-300 px-4 py-2">Cholesterol</td><td class="border border-gray-300 px-4 py-2">70mg</td></tr>
          <tr><td class="border border-gray-300 px-4 py-2">Sodium</td><td class="border border-gray-300 px-4 py-2">~1,700mg</td></tr>
          <tr><td class="border border-gray-300 px-4 py-2">Total Carbs</td><td class="border border-gray-300 px-4 py-2">46g</td></tr>
          <tr><td class="border border-gray-300 px-4 py-2">Protein</td><td class="border border-gray-300 px-4 py-2">24g</td></tr>
        </tbody>
      </table>
      <p class="mt-4">
        <a href="/hot-dog/nutrition/" class="text-red-700 font-semibold hover:underline">View detailed nutrition information &rarr;</a>
      </p>

      <div class="my-8">
        <AdUnit slot="in_content_2" type="in-article" format="auto" minHeight="250px" />
      </div>

      <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Ingredients</h2>
      <p>
        Costco hot dogs are made by Kirkland Signature (Costco's private label) and contain: beef, water, salt, contains 2% or less of corn syrup, dextrose, flavorings, paprika, sodium erythorbate, sodium nitrite.
      </p>
      <p class="mt-4">
        The bun contains: enriched wheat flour, water, sugar, yeast, soybean oil, salt, and preservatives.
      </p>
      <p class="mt-4">
        <a href="/ingredients/" class="text-red-700 font-semibold hover:underline">Full ingredients breakdown &rarr;</a>
      </p>

      <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">Dietary Restrictions</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
        <a href="/faq/dairy-free-buns/" class="block p-4 bg-white border border-gray-200 rounded-lg hover:border-red-300 hover:shadow transition">
          <span class="font-semibold text-gray-900">Dairy Free</span>
          <span class="block text-sm text-gray-600 mt-1">Yes — hot dog and bun contain no dairy</span>
        </a>
        <a href="/hot-dog/gluten-free/" class="block p-4 bg-white border border-gray-200 rounded-lg hover:border-red-300 hover:shadow transition">
          <span class="font-semibold text-gray-900">Gluten Free</span>
          <span class="block text-sm text-gray-600 mt-1">No — bun contains wheat flour</span>
        </a>
        <a href="/faq/halal/" class="block p-4 bg-white border border-gray-200 rounded-lg hover:border-red-300 hover:shadow transition">
          <span class="font-semibold text-gray-900">Halal</span>
          <span class="block text-sm text-gray-600 mt-1">Not officially certified</span>
        </a>
        <a href="/faq/kosher/" class="block p-4 bg-white border border-gray-200 rounded-lg hover:border-red-300 hover:shadow transition">
          <span class="font-semibold text-gray-900">Kosher</span>
          <span class="block text-sm text-gray-600 mt-1">Not officially certified</span>
        </a>
      </div>

      <div class="my-8">
        <AdUnit type="banner" format="medium-rectangle" slot="medium_rectangle_content" minHeight="250px" />
      </div>

      <h2 class="text-2xl font-bold text-gray-900 mt-10 mb-4">The $1.50 Strategy</h2>
      <p>
        Costco's hot dog is a loss leader — the company deliberately keeps the price low to drive foot traffic and reinforce its brand image as the ultimate value retailer. Former CEO W. Craig Jelinek once told Costco co-founder Jim Sinegal that he couldn't keep the price at $1.50. Sinegal's response: "If you raise the price of the hot dog, I will kill you. Figure it out."
      </p>
      <p class="mt-4">
        <a href="/hot-dog/why-so-cheap/" class="text-red-700 font-semibold hover:underline">Read the full business story &rarr;</a>
      </p>
    </div>

    <div class="my-8">
      <AdUnit slot="in_content_3" type="display" format="auto" minHeight="250px" />
    </div>

    <NewsletterSignup
      title="Get the Full Costco Guide"
      description="Weekly tips on Costco's best deals, hidden gems, and money-saving strategies — delivered to your inbox."
    />

    <!-- Ad: Leaderboard Banner -->
    <div class="my-8">
      <AdUnit type="banner" format="leaderboard" slot="leaderboard_header" minHeight="90px" />
    </div>

    <!-- Affiliate Products -->
    <RelatedProducts category="Kitchen" title="Tools for Hot Dog Lovers" />

    <!-- Quick Links -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <h3 class="text-xl font-bold text-gray-900 mb-4">Explore More</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/hot-dog/nutrition/" class="text-red-700 hover:underline font-medium">Nutrition Details</a>
        <a href="/ingredients/" class="text-red-700 hover:underline font-medium">Ingredients List</a>
        <a href="/hot-dog/cooking-at-home/" class="text-red-700 hover:underline font-medium">Cook at Home</a>
        <a href="/faq/" class="text-red-700 hover:underline font-medium">FAQ</a>
      </div>
    </div>
  </article>
</BaseLayout>
