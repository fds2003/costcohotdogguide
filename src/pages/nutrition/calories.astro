---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';
import NutritionCalculator from '../../components/NutritionCalculator.astro';

const comparisons = [
  { name: 'Costco Hot Dog', calories: 570, protein: 24 },
  { name: "McDonald's Big Mac", calories: 550, protein: 25 },
  { name: 'Shake Shack Hot Dog', calories: 420, protein: 18 },
  { name: 'Nathan\'s Famous Hot Dog', calories: 380, protein: 16 },
];
---

<BaseLayout
  title="Costco Hot Dog Calories"
  description="How many calories are in a Costco hot dog? Complete breakdown with bun, without bun, and compared to other fast food."
  type="article"
  publishedAt="2026-04-29"
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Costco Hot Dog Calories</h1>
    <p class="text-lg text-gray-600 mb-8">A complete calorie breakdown of the famous $1.50 Costco hot dog.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      <div class="bg-red-50 border border-red-200 rounded-xl p-6 text-center">
        <p class="text-sm text-red-600 font-medium uppercase tracking-wide">With Bun</p>
        <p class="text-5xl font-bold text-red-700 mt-2">570</p>
        <p class="text-red-600">calories</p>
      </div>
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 text-center">
        <p class="text-sm text-yellow-700 font-medium uppercase tracking-wide">Without Bun</p>
        <p class="text-5xl font-bold text-yellow-700 mt-2">370</p>
        <p class="text-yellow-700">calories</p>
      </div>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">How It Compares</h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-10">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-sm font-semibold">Item</th>
            <th class="px-6 py-3 text-left text-sm font-semibold">Calories</th>
            <th class="px-6 py-3 text-left text-sm font-semibold">Protein</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          {comparisons.map(item => (
            <tr class={item.name.includes('Costco') ? 'bg-red-50' : ''}>
              <td class="px-6 py-3 font-medium">{item.name}</td>
              <td class="px-6 py-3">{item.calories}</td>
              <td class="px-6 py-3">{item.protein}g</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Interactive Nutrition Calculator</h2>
    <NutritionCalculator />

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Breaking Down the Calories</h2>
    <ul class="list-disc list-inside space-y-2 text-gray-700 mb-10">
      <li><strong>Hot dog (meat only):</strong> ~290 calories, mostly from fat and protein</li>
      <li><strong>Bun:</strong> ~180 calories, mostly carbohydrates</li>
      <li><strong>Toppings (ketchup, mustard, relish):</strong> ~20-40 calories</li>
      <li><strong>Soda (20 oz with refill):</strong> ~250 calories (not included in the 570 above)</li>
    </ul>

    <RelatedProducts category="Kitchen" title="Tools to Track Your Nutrition" />
  </article>
</BaseLayout>
