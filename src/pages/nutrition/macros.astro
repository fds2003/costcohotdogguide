---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';
import nutritionData from '../../data/nutrition.json';

const macros = nutritionData.macros;
const servings = nutritionData.servings;

const withBunCalories = servings.hotDogOnly.calories + servings.bun.calories;
const withBunProtein = servings.hotDogOnly.protein + servings.bun.protein;
const withBunFat = servings.hotDogOnly.totalFat + servings.bun.totalFat;
const withBunCarbs = servings.hotDogOnly.totalCarbs + servings.bun.totalCarbs;

const withoutBunCalories = servings.hotDogOnly.calories;
const withoutBunProtein = servings.hotDogOnly.protein;
const withoutBunFat = servings.hotDogOnly.totalFat;
const withoutBunCarbs = servings.hotDogOnly.totalCarbs;
---

<BaseLayout
  title="Costco Hot Dog Macros: Fat, Carbs & Protein"
  description="Complete macronutrient breakdown of the Costco hot dog. See fat, carbohydrate, and protein ratios with and without bun."
  type="article"
  publishedAt="2026-04-29"

  canonical="https://costcohotdogguide.com/hot-dog/protein-vs-calories/">
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Costco Hot Dog Macros</h1>
    <p class="text-lg text-gray-600 mb-8">Understanding the fat, carbohydrate, and protein ratios of America's most famous lunch combo.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      {/* With Bun */}
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4 text-center">With Bun ({withBunCalories} cal)</h2>
        <div class="relative w-48 h-48 mx-auto mb-4">
          <svg viewBox="0 0 100 100" class="w-full h-full -rotate-90">
            <circle cx="50" cy="50" r="40" fill="none" stroke="#e5e7eb" stroke-width="20" />
            <circle cx="50" cy="50" r="40" fill="none" stroke="#fbbf24" stroke-width="20"
              stroke-dasharray={`${macros.withBun.fatPercent * 2.51} 251`} />
            <circle cx="50" cy="50" r="40" fill="none" stroke="#60a5fa" stroke-width="20"
              stroke-dasharray={`${macros.withBun.carbsPercent * 2.51} 251`}
              stroke-dashoffset={`-${macros.withBun.fatPercent * 2.51}`} />
            <circle cx="50" cy="50" r="40" fill="none" stroke="#34d399" stroke-width="20"
              stroke-dasharray={`${macros.withBun.proteinPercent * 2.51} 251`}
              stroke-dashoffset={`-${(macros.withBun.fatPercent + macros.withBun.carbsPercent) * 2.51}`} />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-2xl font-bold text-gray-900">{withBunCalories}</span>
          </div>
        </div>
        <div class="space-y-3">
          <div class="flex items-center justify-between p-3 bg-yellow-50 rounded-lg">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
              <span class="text-gray-700">Fat</span>
            </div>
            <span class="font-bold text-gray-900">{withBunFat}g ({macros.withBun.fatPercent}%)</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-blue-400"></span>
              <span class="text-gray-700">Carbs</span>
            </div>
            <span class="font-bold text-gray-900">{withBunCarbs}g ({macros.withBun.carbsPercent}%)</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-green-400"></span>
              <span class="text-gray-700">Protein</span>
            </div>
            <span class="font-bold text-gray-900">{withBunProtein}g ({macros.withBun.proteinPercent}%)</span>
          </div>
        </div>
      </div>

      {/* Without Bun */}
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4 text-center">Without Bun ({withoutBunCalories} cal)</h2>
        <div class="relative w-48 h-48 mx-auto mb-4">
          <svg viewBox="0 0 100 100" class="w-full h-full -rotate-90">
            <circle cx="50" cy="50" r="40" fill="none" stroke="#e5e7eb" stroke-width="20" />
            <circle cx="50" cy="50" r="40" fill="none" stroke="#fbbf24" stroke-width="20"
              stroke-dasharray={`${macros.withoutBun.fatPercent * 2.51} 251`} />
            <circle cx="50" cy="50" r="40" fill="none" stroke="#60a5fa" stroke-width="20"
              stroke-dasharray={`${macros.withoutBun.carbsPercent * 2.51} 251`}
              stroke-dashoffset={`-${macros.withoutBun.fatPercent * 2.51}`} />
            <circle cx="50" cy="50" r="40" fill="none" stroke="#34d399" stroke-width="20"
              stroke-dasharray={`${macros.withoutBun.proteinPercent * 2.51} 251`}
              stroke-dashoffset={`-${(macros.withoutBun.fatPercent + macros.withoutBun.carbsPercent) * 2.51}`} />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-2xl font-bold text-gray-900">{withoutBunCalories}</span>
          </div>
        </div>
        <div class="space-y-3">
          <div class="flex items-center justify-between p-3 bg-yellow-50 rounded-lg">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
              <span class="text-gray-700">Fat</span>
            </div>
            <span class="font-bold text-gray-900">{withoutBunFat}g ({macros.withoutBun.fatPercent}%)</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-blue-400"></span>
              <span class="text-gray-700">Carbs</span>
            </div>
            <span class="font-bold text-gray-900">{withoutBunCarbs}g ({macros.withoutBun.carbsPercent}%)</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-green-400"></span>
              <span class="text-gray-700">Protein</span>
            </div>
            <span class="font-bold text-gray-900">{withoutBunProtein}g ({macros.withoutBun.proteinPercent}%)</span>
          </div>
        </div>
      </div>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">What These Macros Mean</h2>
    <p class="text-gray-700 mb-4 leading-relaxed">
      The Costco hot dog is a <strong>high-fat, moderate-protein, low-carbohydrate</strong> food when eaten without the bun. With the bun, it becomes a more balanced but still fat-dominant meal.
    </p>
    <p class="text-gray-700 mb-6 leading-relaxed">
      The fat content primarily comes from the beef hot dog itself, which is typically made from a blend of beef trimmings. The protein content is respectable at 24g per serving with bun — comparable to a small chicken breast. The carbohydrate spike is entirely from the bun.
    </p>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Macro Comparison: Costco vs. Alternatives</h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-8">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-sm font-semibold">Food</th>
            <th class="px-6 py-3 text-left text-sm font-semibold">Calories</th>
            <th class="px-6 py-3 text-left text-sm font-semibold">Fat</th>
            <th class="px-6 py-3 text-left text-sm font-semibold">Carbs</th>
            <th class="px-6 py-3 text-left text-sm font-semibold">Protein</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <tr class="bg-red-50">
            <td class="px-6 py-3 font-medium">Costco Hot Dog (with bun)</td>
            <td class="px-6 py-3">570</td>
            <td class="px-6 py-3">34g</td>
            <td class="px-6 py-3">38g</td>
            <td class="px-6 py-3 font-medium text-green-700">24g</td>
          </tr>
          <tr>
            <td class="px-6 py-3 font-medium">Costco Hot Dog (no bun)</td>
            <td class="px-6 py-3">370</td>
            <td class="px-6 py-3">32g</td>
            <td class="px-6 py-3">3g</td>
            <td class="px-6 py-3">18g</td>
          </tr>
          <tr>
            <td class="px-6 py-3 font-medium">McDonald's Big Mac</td>
            <td class="px-6 py-3">550</td>
            <td class="px-6 py-3">30g</td>
            <td class="px-6 py-3">45g</td>
            <td class="px-6 py-3">25g</td>
          </tr>
          <tr>
            <td class="px-6 py-3 font-medium">Shake Shack Hot Dog</td>
            <td class="px-6 py-3">420</td>
            <td class="px-6 py-3">26g</td>
            <td class="px-6 py-3">28g</td>
            <td class="px-6 py-3">18g</td>
          </tr>
          <tr>
            <td class="px-6 py-3 font-medium">Grilled Chicken Breast (4oz)</td>
            <td class="px-6 py-3">185</td>
            <td class="px-6 py-3">4g</td>
            <td class="px-6 py-3">0g</td>
            <td class="px-6 py-3">35g</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">How to Optimize Your Macros</h2>
    <ul class="list-disc list-inside space-y-2 text-gray-700 mb-8">
      <li><strong>For keto/low-carb:</strong> Skip the bun. The hot dog alone has only 3g carbs.</li>
      <li><strong>For high protein:</strong> Add a second hot dog (no bun) for an extra 18g protein.</li>
      <li><strong>For balanced macros:</strong> Eat half the bun or replace with a low-carb wrap.</li>
      <li><strong>For low fat:</strong> Unfortunately, the hot dog is inherently high in fat. Consider the <a href="/dietary/" class="text-red-700 hover:underline">chicken bake</a> instead.</li>
    </ul>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Explore More</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <a href="/nutrition/calories/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-red-300 hover:shadow-sm transition">
        <h3 class="font-semibold text-red-700">Calorie Calculator</h3>
        <p class="text-sm text-gray-600 mt-1">Interactive nutrition with bun and condiment toggles</p>
      </a>
      <a href="/nutrition/weight-watchers-points/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-red-300 hover:shadow-sm transition">
        <h3 class="font-semibold text-red-700">Weight Watchers Points</h3>
        <p class="text-sm text-gray-600 mt-1">SmartPoints calculator for your diet plan</p>
      </a>
      <a href="/nutrition/protein/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-red-300 hover:shadow-sm transition">
        <h3 class="font-semibold text-red-700">Protein Content</h3>
        <p class="text-sm text-gray-600 mt-1">Detailed protein analysis and comparisons</p>
      </a>
      <a href="/dietary/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-red-300 hover:shadow-sm transition">
        <h3 class="font-semibold text-red-700">Dietary Information</h3>
        <p class="text-sm text-gray-600 mt-1">Gluten-free, vegan, halal, kosher, and more</p>
      </a>
    </div>

    <RelatedProducts category="Health" title="Nutrition Tracking Tools" />
  </article>
</BaseLayout>
