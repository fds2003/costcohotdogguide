---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tutorials = [
  {
    title: "How to Cook Costco Hot Dog in Air Fryer",
    description: "The ultimate guide to crispy, juicy air fryer hot dogs in under 10 minutes.",
    href: "/tutorials/air-fryer/",
    tag: "Cooking"
  },
  {
    title: "Costco Hot Dog Calories Without Bun",
    description: "Complete macro breakdown for keto and low-carb eaters.",
    href: "/tutorials/calories-without-bun/",
    tag: "Nutrition"
  },
  {
    title: "Costco Food Court Calories — Complete Guide",
    description: "Nutritional information for every item on the Costco food court menu.",
    href: "/tutorials/food-court-calories/",
    tag: "Nutrition"
  },
];
---

<BaseLayout
  title="Tutorials & Guides — Costco Hot Dog Guide"
  description="Step-by-step tutorials and in-depth guides for cooking, nutrition, and making the most of your Costco food court experience."
  type="article"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 mb-4">
        <span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>
        Kitchen & Tools Layer
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Tutorials & Guides</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Step-by-step instructions and in-depth nutrition guides to help you cook, track, and enjoy Costco hot dogs like a pro.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tutorials.map(t => (
        <a href={t.href} class="block bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md hover:border-green-300 transition group">
          <div class="p-6">
            <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700 mb-3">{t.tag}</span>
            <h2 class="text-lg font-bold text-gray-900 group-hover:text-green-700 transition mb-2">{t.title}</h2>
            <p class="text-sm text-gray-600">{t.description}</p>
            <span class="inline-flex items-center text-sm text-green-600 font-medium mt-4 group-hover:underline">
              Read tutorial
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 bg-green-50 border border-green-200 rounded-xl p-8 text-center">
      <h3 class="text-xl font-bold text-green-900 mb-2">Ready to upgrade your kitchen?</h3>
      <p class="text-gray-600 mb-4">Check out our reviews of the best tools for Costco shoppers.</p>
      <a
        href="/reviews/"
        class="inline-flex items-center px-6 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition"
        onclick="if(typeof gtag!=='undefined')gtag('event','funnel_progression',{from_stage:'B',to_stage:'C',link_text:'Tutorials CTA'});"
      >
        Browse Reviews
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</BaseLayout>
