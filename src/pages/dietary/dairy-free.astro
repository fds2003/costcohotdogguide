---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';

const faqData = [
  {
    question: "Are Costco hot dog buns dairy free?",
    answer: "Yes, Costco hot dog buns do not contain milk, butter, or any dairy-derived ingredients. They are made with enriched wheat flour, water, sugar, yeast, and soybean oil."
  },
  {
    question: "Does the Costco hot dog contain dairy?",
    answer: "No, the hot dog itself is 100% beef and contains no dairy products. However, cross-contamination in the food court is possible."
  },
  {
    question: "Can lactose-intolerant people eat Costco hot dogs?",
    answer: "Generally yes, as both the hot dog and bun are dairy-free. Those with severe dairy allergies should be cautious of cross-contamination."
  }
];
---

<BaseLayout
  title="Are Costco Hot Dogs Dairy Free?"
  description="Yes — Costco hot dogs and buns contain no dairy. Full ingredient analysis for lactose-intolerant and dairy-free shoppers."
  type="faq"
  faqData={faqData}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-green-50 border border-green-200 rounded-xl p-8 text-center mb-10">
      <p class="text-sm text-green-700 font-medium uppercase tracking-wide">Answer</p>
      <p class="text-4xl font-bold text-green-800 mt-2">Yes</p>
      <p class="text-green-700 mt-2">Costco hot dogs and buns are dairy-free</p>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 mb-4">Are Costco Hot Dogs Dairy Free?</h1>
    <p class="text-gray-600 mb-8">A detailed look at the ingredients for lactose-intolerant and dairy-free shoppers.</p>

    <h2 class="text-xl font-bold text-gray-900 mb-3">Hot Dog Ingredients (No Dairy)</h2>
    <ul class="list-disc list-inside space-y-1 text-gray-700 mb-6">
      <li>Beef</li>
      <li>Water</li>
      <li>Salt</li>
      <li>Corn syrup</li>
      <li>Dextrose</li>
      <li>Flavorings</li>
      <li>Paprika</li>
      <li>Sodium erythorbate</li>
      <li>Sodium nitrite</li>
    </ul>

    <h2 class="text-xl font-bold text-gray-900 mb-3">Bun Ingredients (No Dairy)</h2>
    <ul class="list-disc list-inside space-y-1 text-gray-700 mb-6">
      <li>Enriched wheat flour</li>
      <li>Water</li>
      <li>Sugar</li>
      <li>Yeast</li>
      <li>Soybean oil</li>
      <li>Salt</li>
      <li>Preservatives</li>
    </ul>

    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8">
      <p class="text-yellow-800">
        <strong>Cross-contamination note:</strong> While the ingredients themselves contain no dairy, Costco food courts handle many dairy products (cheese pizza, ice cream). Those with severe dairy allergies should exercise caution.
      </p>
    </div>

    <RelatedProducts category="Food" title="Dairy-Free Finds on Amazon" />
  </article>
</BaseLayout>
