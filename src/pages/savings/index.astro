---
import BaseLayout from '../../layouts/BaseLayout.astro';
import gumroadConfig from '../../data/gumroad.json';

const tools = [
  {
    title: 'Membership Calculator',
    description: 'Calculate how much you need to spend at Costco to break even on your membership fee.',
    href: '/savings/membership-calculator/',
    status: 'Live'
  },
  {
    title: 'Price Tracker',
    description: 'Track prices over time and get alerts when your favorite items go on sale.',
    href: '#',
    status: 'Coming Soon'
  },
  {
    title: 'Deal Digest',
    description: 'Weekly roundup of the best Costco deals and hidden gems.',
    href: '#',
    status: 'Coming Soon'
  }
];
---

<BaseLayout
  title="Costco Savings Tools"
  description="Free calculators and tools to help you save money at Costco. Membership ROI calculator, price tracker, and deal alerts."
  type="website"
>
  <section class="bg-red-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Savings Tools</h1>
      <p class="text-xl text-red-100 max-w-2xl">Free calculators and tools to help you maximize savings at Costco.</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Digital Product Promo -->
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 mb-10">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold text-gray-900">Want to Save Even More?</h2>
          <p class="text-gray-600 text-sm mt-1">Get our complete Costco Shopping Guide with strategies, checklists, and insider tips.</p>
        </div>
        <a href="/guides/costco-shopping-guide/" class="inline-block bg-red-700 text-white font-bold px-6 py-2 rounded-lg hover:bg-red-600 transition whitespace-nowrap text-sm">
          Learn More
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {tools.map(tool => (
        <a href={tool.href} class={`block bg-white rounded-xl shadow-sm border p-6 transition ${tool.status === 'Live' ? 'border-gray-200 hover:border-red-300 hover:shadow-lg' : 'border-gray-100 opacity-70 cursor-default'}`}>
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-lg font-bold text-gray-900">{tool.title}</h2>
            <span class={`text-xs font-bold px-2 py-1 rounded-full ${tool.status === 'Live' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600'}`}>
              {tool.status}
            </span>
          </div>
          <p class="text-gray-600 text-sm">{tool.description}</p>
          {tool.status === 'Live' && (
            <span class="inline-block mt-4 text-red-700 font-medium text-sm">Try it now &rarr;</span>
          )}
        </a>
      ))}
    </div>

    <div class="mt-12 bg-gray-100 rounded-xl p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Membership Value Breakdown</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-center">
        <div class="bg-white rounded-lg p-4">
          <p class="text-3xl font-bold text-red-700">$60</p>
          <p class="text-sm text-gray-600 mt-1">Gold Star Annual Fee</p>
        </div>
        <div class="bg-white rounded-lg p-4">
          <p class="text-3xl font-bold text-red-700">$120</p>
          <p class="text-sm text-gray-600 mt-1">Executive Annual Fee</p>
        </div>
        <div class="bg-white rounded-lg p-4">
          <p class="text-3xl font-bold text-green-700">2%</p>
          <p class="text-sm text-gray-600 mt-1">Executive Reward Rate</p>
        </div>
      </div>
      <p class="text-center text-gray-600 mt-4 text-sm">
        Executive members need to spend $3,000/year to break even on the $60 upgrade.
        <a href="/savings/membership-calculator/" class="text-red-700 font-medium hover:underline ml-1">Calculate your ROI &rarr;</a>
      </p>
    </div>
  </div>
</BaseLayout>
