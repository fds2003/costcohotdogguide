---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Costco Membership Calculator"
  description="Calculate how much you need to spend at Costco to break even on your membership fee."
  type="website"
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Membership Calculator</h1>
    <p class="text-lg text-gray-600 mb-8">See how much you need to spend at Costco to break even on your membership.</p>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Membership Type</label>
          <select id="membershipType" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-red-500 focus:border-red-500">
            <option value="60">Gold Star ($60/year)</option>
            <option value="120">Executive ($120/year)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Average Monthly Spending at Costco ($)</label>
          <input type="number" id="monthlySpend" value="300" min="0" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-red-500 focus:border-red-500" />
        </div>
        <button id="calculateBtn" class="w-full bg-red-700 text-white font-semibold py-3 rounded-lg hover:bg-red-600 transition">
          Calculate
        </button>
      </div>
    </div>

    <div id="results" class="hidden bg-green-50 border border-green-200 rounded-xl p-6 text-center">
      <p class="text-sm text-green-700 font-medium">Annual Spending</p>
      <p class="text-4xl font-bold text-green-800 mt-1" id="annualSpend">$3,600</p>
      <div class="mt-4 grid grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-600">Membership Fee</p>
          <p class="text-xl font-bold text-gray-900" id="feeDisplay">$60</p>
        </div>
        <div>
          <p class="text-sm text-gray-600">Break-even</p>
          <p class="text-xl font-bold text-green-700" id="breakEven">2.0 months</p>
        </div>
      </div>
      <div id="executiveBonus" class="hidden mt-4 pt-4 border-t border-green-200">
        <p class="text-sm text-green-700">Executive 2% Reward</p>
        <p class="text-2xl font-bold text-green-800" id="rewardAmount">$72</p>
        <p class="text-sm text-gray-600">Annual reward check</p>
      </div>
    </div>
  </div>

  <script>
    const btn = document.getElementById('calculateBtn');
    const membershipSelect = document.getElementById('membershipType') as HTMLSelectElement;
    const monthlyInput = document.getElementById('monthlySpend') as HTMLInputElement;
    const results = document.getElementById('results');
    const annualSpendEl = document.getElementById('annualSpend');
    const feeDisplayEl = document.getElementById('feeDisplay');
    const breakEvenEl = document.getElementById('breakEven');
    const execBonus = document.getElementById('executiveBonus');
    const rewardAmount = document.getElementById('rewardAmount');

    function calculate() {
      const fee = parseInt(membershipSelect.value);
      const monthly = parseFloat(monthlyInput.value) || 0;
      const annual = monthly * 12;
      const breakEvenMonths = monthly > 0 ? (fee / monthly).toFixed(1) : '0';

      if (annualSpendEl) annualSpendEl.textContent = `$${annual.toLocaleString()}`;
      if (feeDisplayEl) feeDisplayEl.textContent = `$${fee}`;
      if (breakEvenEl) breakEvenEl.textContent = `${breakEvenMonths} months`;

      if (fee === 120) {
        const reward = Math.round(annual * 0.02);
        if (execBonus) execBonus.classList.remove('hidden');
        if (rewardAmount) rewardAmount.textContent = `$${reward}`;
      } else {
        if (execBonus) execBonus.classList.add('hidden');
      }

      if (results) results.classList.remove('hidden');
    }

    btn?.addEventListener('click', calculate);
    calculate();
  </script>
</BaseLayout>
