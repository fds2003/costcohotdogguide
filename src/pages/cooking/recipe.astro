---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';

const ingredients = [
  { item: 'Kirkland Signature Beef Franks', amount: '4', note: 'Or other all-beef hot dogs' },
  { item: 'Hot dog buns', amount: '4', note: 'Soft, not toasted' },
  { item: 'Yellow mustard', amount: '4 tbsp', note: 'French\'s or equivalent' },
  { item: 'Ketchup', amount: '2 tbsp', note: 'Optional' },
  { item: 'Sweet relish', amount: '2 tbsp', note: 'Heinz or equivalent' },
  { item: 'White onion', amount: '1 small', note: 'Finely diced' },
];

const steps = [
  {
    title: 'Prepare the Water Bath',
    text: 'Fill a large pot with water and bring to a gentle simmer over medium heat. The water should be hot but not boiling aggressively — around 180°F (82°C) is ideal.',
    image: null
  },
  {
    title: 'Cook the Hot Dogs',
    text: 'Add hot dogs to the simmering water. Cook for 5-7 minutes, turning occasionally, until heated through. Internal temperature should reach 160°F (71°C). Remove with tongs and set aside.',
    image: null
  },
  {
    title: 'Steam the Buns',
    text: 'Place a steamer basket over the hot dog water. Add buns and steam for 30-60 seconds until soft and warm. Alternatively, wrap in damp paper towel and microwave 15 seconds.',
    image: null
  },
  {
    title: 'Prepare Toppings',
    text: 'While hot dogs cook, finely dice the white onion. Set out mustard, ketchup, and relish in squeeze bottles or small bowls.',
    image: null
  },
  {
    title: 'Assemble',
    text: 'Place one hot dog in each steamed bun. Add mustard in a zigzag pattern across the top. Add a thin line of ketchup if desired. Spoon relish along one side. Generously sprinkle diced onions over the top.',
    image: null
  },
  {
    title: 'Serve Immediately',
    text: 'Serve hot with a 20 oz fountain soda (Pepsi products preferred for authenticity). Consume while warm — steamed buns cool quickly.',
    image: null
  }
];
---

<BaseLayout
  title="Costco Hot Dog Recipe: Make It at Home"
  description="Step-by-step recipe for making Costco-style hot dogs at home. Ingredients, measurements, cooking times, and serving suggestions."
  type="howto"
  publishedAt="2026-04-29"
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Costco Hot Dog Recipe</h1>
    <p class="text-lg text-gray-600 mb-8">The closest you can get to the food court experience without a membership card. Serves 4.</p>

    <div class="bg-red-50 border border-red-200 rounded-xl p-6 mb-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div>
          <p class="text-2xl font-bold text-red-700">20 min</p>
          <p class="text-sm text-red-600">Total Time</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-red-700">5 min</p>
          <p class="text-sm text-red-600">Prep Time</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-red-700">15 min</p>
          <p class="text-sm text-red-600">Cook Time</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-red-700">4</p>
          <p class="text-sm text-red-600">Servings</p>
        </div>
      </div>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Ingredients</h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
      <ul class="space-y-3">
        {ingredients.map(ing => (
          <li class="flex justify-between items-center border-b border-gray-100 pb-2 last:border-0">
            <span class="text-gray-700">{ing.item}</span>
            <span class="text-gray-900 font-medium">{ing.amount} <span class="text-gray-500 text-sm">({ing.note})</span></span>
          </li>
        ))}
      </ul>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Equipment Needed</h2>
    <ul class="list-disc list-inside space-y-1 text-gray-700 mb-8">
      <li>Large pot or deep skillet</li>
      <li>Tongs</li>
      <li>Steamer basket (optional)</li>
      <li>Cutting board and sharp knife</li>
      <li>Meat thermometer (recommended)</li>
    </ul>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Instructions</h2>
    <div class="space-y-6 mb-10">
      {steps.map((step, i) => (
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center font-bold">{i + 1}</div>
          <div>
            <h3 class="font-bold text-gray-900">{step.title}</h3>
            <p class="text-gray-700 leading-relaxed">{step.text}</p>
          </div>
        </div>
      ))}
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Chef's Notes</h2>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-8">
      <ul class="list-disc list-inside space-y-2 text-yellow-800 text-sm">
        <li>For the most authentic texture, use a hot dog roller grill instead of boiling. Roller-grilled hot dogs have the characteristic snap and evenly browned surface.</li>
        <li>If you prefer a charred flavor, finish boiled hot dogs on a hot grill or cast-iron skillet for 1 minute per side.</li>
        <li>The bun is just as important as the hot dog. Avoid toasted or crusty artisan buns — the Costco experience demands a soft, pillowy steamed bun.</li>
        <li>Yellow mustard is non-negotiable. Dijon, whole grain, or spicy mustard will completely change the flavor profile.</li>
      </ul>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Nutrition (Per Serving)</h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-8">
      <table class="w-full">
        <tbody class="divide-y divide-gray-200">
          <tr><td class="px-6 py-3 font-medium">Calories</td><td class="px-6 py-3">570</td></tr>
          <tr><td class="px-6 py-3 font-medium">Protein</td><td class="px-6 py-3">24g</td></tr>
          <tr><td class="px-6 py-3 font-medium">Total Fat</td><td class="px-6 py-3">34g</td></tr>
          <tr><td class="px-6 py-3 font-medium">Carbohydrates</td><td class="px-6 py-3">46g</td></tr>
          <tr><td class="px-6 py-3 font-medium">Sodium</td><td class="px-6 py-3">1,750mg</td></tr>
        </tbody>
      </table>
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Serving Suggestions</h2>
    <ul class="list-disc list-inside space-y-2 text-gray-700 mb-8">
      <li>Serve with a 20 oz Pepsi or Diet Pepsi for the full food court experience</li>
      <li>Add a side of <a href="/articles/food-court-menu/" class="text-red-700 hover:underline">Costco pizza</a> for the ultimate warehouse meal</li>
      <li>Pair with a chocolate-dipped ice cream bar if you really want to go all out</li>
      <li>For a healthier option, skip the bun and serve over a bed of sauerkraut</li>
    </ul>

    <h2 class="text-2xl font-bold text-gray-900 mb-4">Explore More</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <a href="/cooking/at-home/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-red-300 hover:shadow-sm transition">
        <h3 class="font-semibold text-red-700">Cooking at Home Guide</h3>
        <p class="text-sm text-gray-600 mt-1">Equipment, sourcing, and step-by-step methods</p>
      </a>
      <a href="/ingredients/ingredients-list/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-red-300 hover:shadow-sm transition">
        <h3 class="font-semibold text-red-700">Complete Ingredients</h3>
        <p class="text-sm text-gray-600 mt-1">What's in the official Costco hot dog</p>
      </a>
      <a href="/nutrition/calories/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-red-300 hover:shadow-sm transition">
        <h3 class="font-semibold text-red-700">Calorie Calculator</h3>
        <p class="text-sm text-gray-600 mt-1">Interactive nutrition with condiment toggles</p>
      </a>
      <a href="/articles/food-court-menu/" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-red-300 hover:shadow-sm transition">
        <h3 class="font-semibold text-red-700">Full Food Court Menu</h3>
        <p class="text-sm text-gray-600 mt-1">Every item, price, and calorie count</p>
      </a>
    </div>

    <RelatedProducts category="Kitchen" title="Recipe Essentials" />
  </article>
</BaseLayout>
