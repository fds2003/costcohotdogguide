---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';
---

<BaseLayout
  title="Costco Hot Dog in Air Fryer"
  description="How to cook Costco hot dogs in an air fryer. Crispy skin, juicy inside — step by step guide."
  type="howto"
  publishedAt="2026-04-29"
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Costco Hot Dog in Air Fryer</h1>
    <p class="text-lg text-gray-600 mb-8">The best way to recreate that food court snap at home.</p>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Instructions</h2>
      <ol class="list-decimal list-inside space-y-3 text-gray-700">
        <li><strong>Preheat</strong> your air fryer to 400 degrees F (200 C) for 2-3 minutes</li>
        <li><strong>Score</strong> the hot dogs lightly with a knife (optional, but helps with crispiness)</li>
        <li><strong>Place</strong> hot dogs in the basket, leaving space between each one</li>
        <li><strong>Cook</strong> for 5-6 minutes, shaking the basket halfway through</li>
        <li><strong>Check</strong> for your desired level of browning — add 1-2 minutes if needed</li>
        <li><strong>Toast</strong> the bun separately for 1-2 minutes at 350 degrees F</li>
        <li><strong>Serve</strong> immediately with your favorite toppings</li>
      </ol>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="bg-green-50 border border-green-200 rounded-lg p-5">
        <h3 class="font-bold text-green-800 mb-2">Pro Tips</h3>
        <ul class="list-disc list-inside text-sm text-green-800 space-y-1">
          <li>Do not overcook — they can burst</li>
          <li>Shake basket halfway for even browning</li>
          <li>Toast buns separately to avoid sogginess</li>
        </ul>
      </div>
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-5">
        <h3 class="font-bold text-yellow-800 mb-2">Timing Guide</h3>
        <ul class="list-disc list-inside text-sm text-yellow-800 space-y-1">
          <li>5 min — Lightly browned</li>
          <li>6 min — Classic snap</li>
          <li>7 min — Extra crispy</li>
        </ul>
      </div>
    </div>

    <RelatedProducts category="Kitchen" title="Best Air Fryers for Hot Dogs" />
  </article>
</BaseLayout>
